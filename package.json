{
  "name": "eleventy-plugin-mirador",
  "version": "2.0.1",
  "description": "11ty plugin for embedding the Mirador image viewer.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "format": "prettier --write \"src/**/*.js\"",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --fix --ext .js",
    "demo": "eleventy --config=demo/.eleventy.js --input=demo --output=demo/_site --serve --port=8080",
    "test": "jest --config jest.config.js",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alxp/eleventy-plugin-mirador.git"
  },
  "keywords": [
    "11ty",
    "eleventy",
    "eleventy-plugin",
    "islandty",
    "mirador"
  ],
  "author": {
    "name": "Alexander O'Neill",
    "email": "aloneill@gmail.com",
    "url": "https://alxp.ca"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alxp/eleventy-plugin-mirador/issues"
  },
  "homepage": "https://github.com/alxp/eleventy-plugin-mirador/#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "eslint": "8.56.0",
    "eslint-plugin-jest": "27.9.0",
    "jest": "29.7.0",
    "prettier": "3.2.5"
  },
  "files": [
    "src/index.js",
    "src/libs/**/*"
  ],
  "engines": {
    "node": ">=14"
  }
}
